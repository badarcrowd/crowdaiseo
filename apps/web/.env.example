# =========================
# Application
# =========================
NEXT_PUBLIC_APP_NAME="AIV"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# =========================
# Supabase
# =========================
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""           # server-only, NEVER expose
SUPABASE_JWT_SECRET=""                  # server-only

# =========================
# Database (Prisma → Supabase Postgres)
# =========================
DATABASE_URL=""                         # pooled connection (pgbouncer) for runtime
DIRECT_URL=""                           # direct connection for migrations

# =========================
# Redis / Queue
# =========================
REDIS_URL="redis://localhost:6379"
QUEUE_PREFIX="aiv"

# =========================
# AI Providers (placeholders — orchestrator selects per-task)
# =========================
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GOOGLE_AI_API_KEY=""
PERPLEXITY_API_KEY=""

# =========================
# Observability
# =========================
LOG_LEVEL="info"                        # trace|debug|info|warn|error|fatal
SENTRY_DSN=""

# =========================
# Billing (placeholder)
# =========================
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# =========================
# Feature flags / Misc
# =========================
ENCRYPTION_KEY=""                       # 32-byte base64; used for at-rest field encryption
RATE_LIMIT_REDIS_PREFIX="rl"
